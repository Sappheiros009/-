using BepInEx;
using BepInEx.Logging;
using HarmonyLib;
using System;
using System.Collections;
using System.Collections.Generic;
using UnityEngine;
using UnityEngine.SceneManagement;

[BepInPlugin(
    PluginGUID,
    PluginName,
    PluginVersion)]
public sealed class Runup : BaseUnityPlugin
{
    public const string PluginGUID =
        "Sapphire009.Runup";

    public const string PluginName =
        "Runup";

    public const string PluginVersion =
        "1.0.0";

    private const string BuildMarker =
        "PalJump-AboveJumpingPEAK-R3";

    /*
     * 현재 JumpingPEAK의 일반 강화 점프:
     *
     * 원본 jumpImpulse × 5
     */
    private const float JumpingPeakJumpMultiplier =
        5f;

    /*
     * 이전 Runup 최종 점프력:
     *
     * 원본 × 62.5
     *
     * 현재 점프력에서 1/3을 감소시키므로
     * 기존 점프력의 2/3만 적용합니다.
     *
     * 62.5 × 2/3
     * = 약 41.6667
     *
     * 원본 × 5 × 8.333333
     * = 원본 × 약 41.6667
     */
    private const float RunupRelativeMultiplier =
        25f /
        3f;

    /*
     * PEAK 원본 Pal Jump에는 내부적으로
     * jumpMult = 2가 적용됩니다.
     */
    private const float NativePalJumpMultiplier =
        2f;

    /*
     * 최종 협동 점프를 원본 ×약 41.6667로 만들기 위한
     * 실제 jumpImpulse 배율입니다.
     *
     * 약 20.8333 × PEAK 내부 Pal Jump 2배
     * = 최종 원본 대비 약 41.6667배
     */
    private const float RunupImpulseMultiplier =
        (
            JumpingPeakJumpMultiplier *
            RunupRelativeMultiplier
        ) /
        NativePalJumpMultiplier;

    private const float FinalEffectiveMultiplier =
        JumpingPeakJumpMultiplier *
        RunupRelativeMultiplier;

    /*
     * 원본 점프력이 협동 점프 이후에도 남지 않도록
     * 실제 점프가 끝난 뒤 원본값으로 복구합니다.
     */
    private const int MaximumRestoreWaitFrames =
        120;

    private const int RestoreSafetyFrames =
        4;

    private const int MaximumLogCount =
        50;

    internal static ManualLogSource ModLogger;

    private static readonly Dictionary<int, float>
        OriginalJumpImpulses =
            new Dictionary<int, float>();

    private static readonly Dictionary<int, int>
        ActiveRestoreTokens =
            new Dictionary<int, int>();

    private static readonly WaitForFixedUpdate
        WaitForPhysics =
            new WaitForFixedUpdate();

    private static int nextRestoreToken;

    private static int appliedLogCount;
    private static int restoredLogCount;
    private static int rejectedLogCount;

    private Harmony harmony;

    private void Awake()
    {
        ModLogger =
            Logger;

        harmony =
            new Harmony(
                PluginGUID);

        harmony.PatchAll();

        Logger.LogInfo(
            $"{PluginName} {PluginVersion} loaded. " +
            $"Build: {BuildMarker}. " +
            $"Runup impulse multiplier=" +
            $"{RunupImpulseMultiplier:0.000}. " +
            $"Final effective multiplier=" +
            $"{FinalEffectiveMultiplier:0.000}. " +
            "Pal Jump strength was reduced by one third " +
            "and is now two thirds of the previous value.");
    }

    private void OnDestroy()
    {
        OriginalJumpImpulses.Clear();
        ActiveRestoreTokens.Clear();

        nextRestoreToken = 0;

        appliedLogCount = 0;
        restoredLogCount = 0;
        rejectedLogCount = 0;

        if (harmony != null)
        {
            harmony.UnpatchSelf();
            harmony = null;
        }

        ModLogger = null;
    }

    internal static bool IsAirportScene()
    {
        string sceneName =
            SceneManager.GetActiveScene().name;

        if (string.IsNullOrEmpty(
                sceneName))
        {
            return false;
        }

        return sceneName.IndexOf(
                   "Airport",
                   StringComparison.OrdinalIgnoreCase) >= 0;
    }

    private static Character ResolveCharacter(
        Component component)
    {
        if (component == null)
        {
            return null;
        }

        Character character =
            component.GetComponent<Character>();

        if (character == null)
        {
            character =
                component.GetComponentInParent<Character>();
        }

        return character;
    }

    /*
     * CharacterMovement가 처음 생성됐을 때
     * PEAK의 원본 jumpImpulse를 저장합니다.
     */
    private static void StoreOriginalJumpImpulse(
        CharacterMovement movement,
        bool overwrite)
    {
        if (movement == null)
        {
            return;
        }

        float currentJumpImpulse =
            movement.jumpImpulse;

        if (currentJumpImpulse <= 0f)
        {
            return;
        }

        int movementId =
            movement.GetInstanceID();

        if (!overwrite &&
            OriginalJumpImpulses.ContainsKey(
                movementId))
        {
            return;
        }

        OriginalJumpImpulses[movementId] =
            currentJumpImpulse;
    }

    private static bool TryGetOriginalJumpImpulse(
        CharacterMovement movement,
        out float originalJumpImpulse)
    {
        originalJumpImpulse =
            0f;

        if (movement == null)
        {
            return false;
        }

        int movementId =
            movement.GetInstanceID();

        if (OriginalJumpImpulses.TryGetValue(
                movementId,
                out originalJumpImpulse))
        {
            return originalJumpImpulse > 0f;
        }

        /*
         * Start 패치보다 늦게 플러그인이 적용되는 상황을
         * 대비한 보조 저장 경로입니다.
         *
         * JumpingPEAK 패치 뒤에 실행되므로 Pal Jump에서는
         * 현재 값이 원본 jumpImpulse로 복구된 상태입니다.
         */
        StoreOriginalJumpImpulse(
            movement,
            false);

        return OriginalJumpImpulses.TryGetValue(
                   movementId,
                   out originalJumpImpulse) &&
               originalJumpImpulse > 0f;
    }

    private static int CreateRestoreToken(
        CharacterMovement movement)
    {
        nextRestoreToken++;

        if (nextRestoreToken <= 0)
        {
            nextRestoreToken =
                1;
        }

        int movementId =
            movement.GetInstanceID();

        ActiveRestoreTokens[movementId] =
            nextRestoreToken;

        return nextRestoreToken;
    }

    private static bool IsCurrentRestoreToken(
        CharacterMovement movement,
        int restoreToken)
    {
        if (movement == null)
        {
            return false;
        }

        int currentToken;

        return ActiveRestoreTokens.TryGetValue(
                   movement.GetInstanceID(),
                   out currentToken) &&
               currentToken == restoreToken;
    }

    private static void RestoreOriginalJumpImpulse(
        CharacterMovement movement,
        float originalJumpImpulse,
        int restoreToken,
        string reason)
    {
        if (!IsCurrentRestoreToken(
                movement,
                restoreToken))
        {
            return;
        }

        int movementId =
            movement.GetInstanceID();

        if (movement != null &&
            originalJumpImpulse > 0f)
        {
            movement.jumpImpulse =
                originalJumpImpulse;
        }

        ActiveRestoreTokens.Remove(
            movementId);

        if (restoredLogCount <
            MaximumLogCount)
        {
            restoredLogCount++;

            ModLogger?.LogInfo(
                $"[Runup] Original jump impulse restored " +
                $"({restoredLogCount}/{MaximumLogCount}). " +
                $"Impulse={originalJumpImpulse:0.000}, " +
                $"Reason={reason}, " +
                $"Scene=" +
                $"{SceneManager.GetActiveScene().name}");
        }
    }

    /*
     * PEAK의 실제 Pal Jump 코루틴이 jumpImpulse를
     * 모두 사용한 이후 원본값을 복구합니다.
     */
    private static IEnumerator RestoreAfterPalJump(
        CharacterMovement movement,
        Character character,
        float originalJumpImpulse,
        float previousSincePalJump,
        int restoreToken)
    {
        if (movement == null ||
            character == null ||
            character.data == null)
        {
            RestoreOriginalJumpImpulse(
                movement,
                originalJumpImpulse,
                restoreToken,
                "InvalidCharacter");

            yield break;
        }

        bool palJumpStarted =
            false;

        /*
         * 원본 JumpRpc가 실행되면 다음 중 하나가 발생합니다.
         *
         * 1. chargingJump가 true가 됨
         * 2. sincePalJump가 0으로 초기화됨
         */
        for (int frame = 0;
             frame < MaximumRestoreWaitFrames;
             frame++)
        {
            if (!IsCurrentRestoreToken(
                    movement,
                    restoreToken))
            {
                yield break;
            }

            if (movement == null ||
                character == null ||
                character.data == null)
            {
                RestoreOriginalJumpImpulse(
                    movement,
                    originalJumpImpulse,
                    restoreToken,
                    "CharacterDestroyed");

                yield break;
            }

            if (character.data.dead ||
                character.data.fullyPassedOut)
            {
                RestoreOriginalJumpImpulse(
                    movement,
                    originalJumpImpulse,
                    restoreToken,
                    "CharacterUnavailable");

                yield break;
            }

            bool sincePalJumpWasReset =
                character.data.sincePalJump <
                previousSincePalJump - 0.0001f;

            if (character.data.chargingJump ||
                sincePalJumpWasReset)
            {
                palJumpStarted =
                    true;

                break;
            }

            yield return
                WaitForPhysics;
        }

        /*
         * 다른 패치가 원본 JumpRpc를 차단한 경우에는
         * 강화값을 유지하지 않고 즉시 복구합니다.
         */
        if (!palJumpStarted)
        {
            RestoreOriginalJumpImpulse(
                movement,
                originalJumpImpulse,
                restoreToken,
                "PalJumpDidNotStart");

            yield break;
        }

        /*
         * PEAK 점프 준비 단계가 끝날 때까지 기다립니다.
         * 이 구간에서 실제 jumpImpulse가 소비됩니다.
         */
        for (int frame = 0;
             frame < MaximumRestoreWaitFrames;
             frame++)
        {
            yield return
                WaitForPhysics;

            if (!IsCurrentRestoreToken(
                    movement,
                    restoreToken))
            {
                yield break;
            }

            if (movement == null ||
                character == null ||
                character.data == null)
            {
                RestoreOriginalJumpImpulse(
                    movement,
                    originalJumpImpulse,
                    restoreToken,
                    "CharacterDestroyedDuringJump");

                yield break;
            }

            if (!character.data.chargingJump)
            {
                /*
                 * chargingJump가 해제된 직후에도
                 * 원본 점프 코루틴이 같은 물리 프레임에서
                 * 힘을 적용할 수 있으므로 추가로 기다립니다.
                 */
                for (int safetyFrame = 0;
                     safetyFrame < RestoreSafetyFrames;
                     safetyFrame++)
                {
                    yield return
                        WaitForPhysics;

                    if (!IsCurrentRestoreToken(
                            movement,
                            restoreToken))
                    {
                        yield break;
                    }
                }

                RestoreOriginalJumpImpulse(
                    movement,
                    originalJumpImpulse,
                    restoreToken,
                    "PalJumpCompleted");

                yield break;
            }
        }

        RestoreOriginalJumpImpulse(
            movement,
            originalJumpImpulse,
            restoreToken,
            "RestoreTimeout");
    }

    /*
     * 캐릭터가 생성될 때 원본 jumpImpulse를 확보합니다.
     */
    [HarmonyPatch(
        typeof(CharacterMovement),
        "Start")]
    private static class CharacterMovementStartPatch
    {
        [HarmonyPostfix]
        private static void Postfix(
            CharacterMovement __instance)
        {
            StoreOriginalJumpImpulse(
                __instance,
                true);
        }
    }

    /*
     * PEAK의 협동 Pal Jump만 강화합니다.
     *
     * 일반 점프는 isPalJump == false이므로
     * 이 패치에서 변경하지 않습니다.
     */
    [HarmonyPatch(
        typeof(CharacterMovement),
        nameof(CharacterMovement.JumpRpc),
        new Type[]
        {
            typeof(bool)
        })]
    private static class CharacterMovementJumpRpcPatch
    {
        private sealed class PalJumpPatchState
        {
            public bool Applied;

            public Character Character;

            public float OriginalJumpImpulse;

            public float PreviousSincePalJump;

            public int RestoreToken;
        }

        /*
         * JumpingPEAK가 Pal Jump 값을 원본으로 복구한 다음
         * Runup의 강화값을 적용해야 합니다.
         */
        [HarmonyPrefix]
        [HarmonyPriority(Priority.Last)]
        [HarmonyAfter(
            new string[]
            {
                "Sapphire009.JumpingPEAK"
            })]
        private static void Prefix(
            CharacterMovement __instance,
            bool __0,
            out PalJumpPatchState __state)
        {
            __state =
                new PalJumpPatchState();

            bool isPalJump =
                __0;

            if (!isPalJump)
            {
                return;
            }

            if (__instance == null)
            {
                LogRejected(
                    "CharacterMovement is null.");

                return;
            }

            Character character =
                ResolveCharacter(
                    __instance);

            if (character == null)
            {
                LogRejected(
                    "Character could not be resolved.");

                return;
            }

            /*
             * 실제로 발사되는 플레이어의 소유 클라이언트에서만
             * 물리 점프력을 변경합니다.
             */
            if (!character.IsLocal)
            {
                return;
            }

            if (character.data == null)
            {
                LogRejected(
                    "Character.data is null.");

                return;
            }

            if (IsAirportScene())
            {
                return;
            }

            if (character.data.dead ||
                character.data.fullyPassedOut)
            {
                return;
            }

            float originalJumpImpulse;

            if (!TryGetOriginalJumpImpulse(
                    __instance,
                    out originalJumpImpulse))
            {
                LogRejected(
                    "Original jumpImpulse could not be resolved.");

                return;
            }

            float runupJumpImpulse =
                originalJumpImpulse *
                RunupImpulseMultiplier;

            int restoreToken =
                CreateRestoreToken(
                    __instance);

            __state.Applied =
                true;

            __state.Character =
                character;

            __state.OriginalJumpImpulse =
                originalJumpImpulse;

            __state.PreviousSincePalJump =
                character.data.sincePalJump;

            __state.RestoreToken =
                restoreToken;

            /*
             * PEAK 내부 Pal Jump 2배가 이후 추가되므로
             * 최종 수직 계수는 원본의 약 41.6667배가 됩니다.
             */
            __instance.jumpImpulse =
                runupJumpImpulse;

            if (appliedLogCount <
                MaximumLogCount)
            {
                appliedLogCount++;

                ModLogger?.LogInfo(
                    $"[Runup] Enhanced Pal Jump applied " +
                    $"({appliedLogCount}/{MaximumLogCount}). " +
                    $"OriginalImpulse={originalJumpImpulse:0.000}, " +
                    $"RunupImpulseMultiplier=" +
                    $"{RunupImpulseMultiplier:0.000}, " +
                    $"PatchedImpulse={runupJumpImpulse:0.000}, " +
                    $"NativePalMultiplier=" +
                    $"{NativePalJumpMultiplier:0.000}, " +
                    $"FinalEffectiveMultiplier=" +
                    $"{FinalEffectiveMultiplier:0.000}, " +
                    $"Scene=" +
                    $"{SceneManager.GetActiveScene().name}");
            }
        }

        /*
         * 원본 JumpRpc가 점프 코루틴을 만든 다음
         * 복구 감시 코루틴을 시작합니다.
         */
        [HarmonyPostfix]
        [HarmonyPriority(Priority.Last)]
        [HarmonyAfter(
            new string[]
            {
                "Sapphire009.JumpingPEAK"
            })]
        private static void Postfix(
            CharacterMovement __instance,
            PalJumpPatchState __state)
        {
            if (__instance == null ||
                __state == null ||
                !__state.Applied ||
                __state.Character == null)
            {
                return;
            }

            __instance.StartCoroutine(
                RestoreAfterPalJump(
                    __instance,
                    __state.Character,
                    __state.OriginalJumpImpulse,
                    __state.PreviousSincePalJump,
                    __state.RestoreToken));
        }
    }

    private static void LogRejected(
        string reason)
    {
        if (rejectedLogCount >=
            MaximumLogCount)
        {
            return;
        }

        rejectedLogCount++;

        ModLogger?.LogWarning(
            $"[Runup] Pal Jump boost rejected " +
            $"({rejectedLogCount}/{MaximumLogCount}). " +
            $"Reason={reason}, " +
            $"Scene=" +
            $"{SceneManager.GetActiveScene().name}");
    }
}
